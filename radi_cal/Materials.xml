  <material name="LuAg_Ce_WLS">
    <propertiestable>
      <!-- Decays at 70ns based on the Ce3+ transition lifetime -->
      <property name="WLSTIMECONSTANT" value="70" unit="ns"/>

      <!-- Self-scintillation: direct dE/dx in the fiber, matching Walker's
           RADiCALsimLuAG DetectorConstruction.cc. His base yield is
           22000 ph/MeV (RADICAL_SCINT_YIELD default 1.0), scaled by decay
           60ns in his sim. Kept your 70ns Ce3+ decay here since it's the more
           carefully sourced number and his sim's 60ns is close enough to be
           a rounding choice, not a physics disagreement. Note: unlike DSB1,
           there's no paper-tuned scale factor documented for LuAG in his
           notes, so 22000 is the raw untuned default. Treat it as a starting
           point to calibrate against detected photon counts, not a
           validated final value. -->
      <property name="SCINTILLATIONYIELD"          value="22000"/>
      <property name="RESOLUTIONSCALE"              value="1.0"/>
      <property name="SCINTILLATIONTIMECONSTANT1"   value="70" unit="ns"/>
      <property name="SCINTILLATIONYIELD1"          value="1.0"/>

      <!-- Self-scint emission spectrum: reuses the WLS emission shape below,
           same fluorescence line whether excited by dE/dx directly or by an
           absorbed LYSO photon. -->
      <propertyvector name="SCINTILLATIONCOMPONENT1" energyunit="eV">
        <ve energy="1.55" value="0.00"/>  <!-- 800nm cutoff -->
        <ve energy="1.77" value="0.15"/>  <!-- 700nm -->
        <ve energy="2.07" value="0.60"/>  <!-- 600nm -->
        <ve energy="2.31" value="1.00"/>  <!-- 535nm, peak emission -->
        <ve energy="2.48" value="0.45"/>  <!-- 500nm -->
        <ve energy="2.61" value="0.00"/>  <!-- 475nm cutoff -->
        <ve energy="6.20" value="0.00"/>
      </propertyvector>

      <!-- Refractive index flat across the emission spectrum at 1.84 -->
      <propertyvector name="RINDEX" energyunit="eV">
        <ve energy="1.55" value="1.84"/>
        <ve energy="2.00" value="1.84"/>
        <ve energy="2.31" value="1.84"/>
        <ve energy="2.61" value="1.84"/>
        <ve energy="3.10" value="1.84"/>
        <ve energy="6.20" value="1.84"/>
      </propertyvector>

      <!-- Bulk material absorption length: clear path length for shifted green light -->
      <propertyvector name="ABSLENGTH" unit="m" energyunit="eV">
        <ve energy="1.55" value="5.0"/>
        <ve energy="2.31" value="5.0"/>
        <ve energy="6.20" value="5.0"/>
      </propertyvector>

      <!-- WLS Absorption Length: unchanged from your original -->
      <propertyvector name="WLSABSLENGTH" unit="m" energyunit="eV">
        <ve energy="1.55" value="1000.0"/>
        <ve energy="2.31" value="1000.0"/>
        <ve energy="2.48" value="1.000"/>
        <ve energy="2.64" value="0.005"/>
        <ve energy="2.75" value="0.002"/>
        <ve energy="2.90" value="0.005"/>
        <ve energy="3.54" value="1000.0"/>
        <ve energy="6.20" value="1000.0"/>
      </propertyvector>

      <!-- WLS Re-emission Spectrum: unchanged from your original -->
      <propertyvector name="WLSCOMPONENT" energyunit="eV">
        <ve energy="1.55" value="0.00"/>
        <ve energy="1.77" value="0.15"/>
        <ve energy="2.07" value="0.60"/>
        <ve energy="2.31" value="1.00"/>
        <ve energy="2.48" value="0.45"/>
        <ve energy="2.61" value="0.00"/>
        <ve energy="6.20" value="0.00"/>
      </propertyvector>
    </propertiestable>
  </material>
  
